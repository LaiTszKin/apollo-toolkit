{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": ["bin/**/*.ts"],
  "exclude": ["node_modules", "dist", ".claude", "resources"],
  "references": [
    { "path": "packages/tui" },
    { "path": "packages/tool-registry" },
    { "path": "packages/tool-utils" },
    { "path": "packages/cli" }
  ]
}
